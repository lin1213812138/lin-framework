# ── 应用 ──
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── MongoDB ──
MONGODB_URI=mongodb://localhost:27017/lin-framework
MONGODB_USER=lin
MONGODB_PASSWORD=

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ──
JWT_SECRET=your-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=15m
JWT_REFRESH_TOKEN_EXPIRES=7d

# ── 文件存储 ──
STORAGE_DRIVER=local
STORAGE_PATH=./uploads

# ── 日志 ──
LOG_LEVEL=debug
LOG_OUTPUT=console

# ── 验证码 ──
CAPTCHA_EXPIRES=300

# ── Rate Limit ──
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
